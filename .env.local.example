# ─────────────────────────────────────────
# .env.local  ← このファイルはGitHubにあげないこと！
# Vercelのダッシュボードにも同じ値を設定してください
# ─────────────────────────────────────────

# Google Sheets
# スプレッドシートのURLの /d/ と /edit の間の文字列
GOOGLE_SHEETS_ID=ここにスプレッドシートのIDを貼る

# Google サービスアカウントキー（JSONをそのまま貼る）
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Google Maps APIキー
NEXT_PUBLIC_GOOGLE_MAPS_KEY=ここにGoogle Maps APIキーを貼る

# Google Geocoding APIキー（Maps APIキーと同じでOK）
GOOGLE_GEOCODING_KEY=ここにGeocoding APIキーを貼る

# Claude API
ANTHROPIC_API_KEY=ここにClaude APIキーを貼る

# Cronの不正実行防止キー（自分で好きな文字列を設定）
CRON_SECRET=my-super-secret-cron-key-2026
